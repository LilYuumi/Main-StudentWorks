<%- include('../partials/header') %>

<!-- Navbar -->
<nav class="bg-idb-blue border-b border-idb-blue-dark sticky top-0 z-40">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-wrap justify-between items-center gap-2 py-2 min-h-[3.5rem]">
      <button class="hamburger-btn" aria-label="Menu"><span></span><span></span><span></span></button>
      <a href="/<%= user.role %>/dashboard" class="flex items-center gap-2">
        <div class="bg-white rounded-lg px-2 py-1 shadow-sm"><img src="/images/logo.png" alt="StudentWorks" class="h-9 w-auto"></div>
                <span class="status-chip ml-1" style="font-size:0.6rem;padding:2px 8px;
          <%= user.role === 'mahasiswa' ? 'background:#E2E8F0;color:#1A365D' : 'background:#FF6B35;color:white' %>">
          <%= user.role === 'mahasiswa' ? 'Mahasiswa' : 'Klien' %>
        </span>
      </a>
      <div class="hidden md:flex md:flex-wrap md:items-center md:gap-4">
        <a href="/<%= user.role %>/dashboard" class="text-sm text-white hover:underline font-medium">← Kembali</a>
      </div>
    </div>
  </div>
</nav>

<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-6 page-fade-in">

  <!-- Project Header -->
  <div class="card p-5 mb-6">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
      <div>
        <h2 class="font-heading text-xl font-bold text-idb-blue-dark"><%= project.judul_proyek %></h2>
        <p class="text-sm text-gray-500 mt-0.5">Chat dengan <strong class="text-idb-charcoal"><%= otherName %></strong></p>
      </div>
      <div class="flex items-center gap-2">
        <%
          let chipClass = 'status-chip--gray';
          if (project.status === 'Sedang Dikerjakan') chipClass = 'status-chip--blue';
          else if (project.status === 'Dalam Peninjauan') chipClass = 'status-chip--amber';
          else if (project.status === 'Selesai') chipClass = 'status-chip--green';
        %>
        <span class="status-chip <%= chipClass %>"><%= project.status %></span>
      </div>
    </div>
  </div>

  <div class="grid lg:grid-cols-3 gap-6">

    <!-- Chat Area (2/3 width) -->
    <div class="lg:col-span-2">
      <div class="card overflow-hidden" style="height:520px; height:min(520px, calc(100vh - 200px)); display:flex; flex-direction:column;">

        <!-- Messages Container -->
        <div id="messages-container" class="flex-1 overflow-y-auto p-4 space-y-3 bg-idb-gray">
          <% if (messages.length === 0) { %>
            <div class="flex items-center justify-center h-full">
              <p class="text-sm text-gray-400 text-center">Belum ada pesan. Mulai percakapan!</p>
            </div>
          <% } else { %>
            <% messages.forEach(msg => { %>
              <% const isMine = msg.sender_id === user.id; %>
              <div class="flex <%= isMine ? 'justify-end' : 'justify-start' %>">
                <div class="max-w-[75%] <%= isMine ? 'bg-idb-blue text-white' : 'bg-white text-idb-charcoal border border-gray-100' %> rounded-2xl px-4 py-2.5" style="<%= isMine ? 'border-bottom-right-radius:4px' : 'border-bottom-left-radius:4px' %>">
                  <% if (!isMine) { %>
                    <p class="text-xs font-semibold mb-0.5 <%= isMine ? 'text-blue-200' : 'text-idb-blue' %>"><%= msg.sender_name %></p>
                  <% } %>
                  <p class="text-sm leading-relaxed whitespace-pre-wrap"><%= msg.message %></p>
                  <p class="text-xs mt-1 <%= isMine ? 'text-blue-200' : 'text-gray-400' %> text-right">
                    <%= new Date(msg.created_at).toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit' }) %>
                  </p>
                </div>
              </div>
            <% }) %>
          <% } %>
        </div>

        <!-- Message Input -->
        <div class="border-t border-gray-100 p-3 bg-white">
          <form method="POST" action="/chat/<%= project.id %>" class="flex gap-2">
            <input type="text" name="message" required placeholder="Ketik pesan..." class="input flex-1" style="border-radius:20px;padding:10px 16px" autocomplete="off">
            <button type="submit" class="btn btn-blue" style="border-radius:20px;padding:10px 20px">
              Kirim
            </button>
          </form>
        </div>
      </div>
    </div>

    <!-- Sidebar: Submissions (1/3 width) -->
    <div class="lg:col-span-1">
      <div class="card p-5" style="max-height:520px;overflow-y:auto;">
        <h3 class="font-heading font-bold text-sm text-idb-blue-dark mb-3">File yang Diunggah</h3>

        <% if (submissions.length === 0) { %>
          <div class="text-center py-6">
            <div class="w-12 h-12 bg-gray-100 rounded-lg flex items-center justify-center mx-auto mb-2">
              <i data-lucide="folder-open" class="w-6 h-6 text-gray-400"></i>
            </div>
            <p class="text-xs text-gray-400">Belum ada file yang diunggah.</p>
          </div>
        <% } else { %>
          <div class="space-y-2">
            <% submissions.forEach(sub => { %>
              <a href="<%= sub.file_path %>" target="_blank" class="block bg-idb-gray hover:bg-gray-100 transition rounded-btn p-3">
                <div class="flex items-center gap-3">
                  <div class="w-10 h-10 bg-white rounded-lg flex items-center justify-center flex-shrink-0">
                    <% if (['.jpg','.jpeg','.png','.gif','.svg'].includes(sub.file_type)) { %>
                      <i data-lucide="image" class="w-5 h-5 text-idb-blue"></i>
                    <% } else if (['.pdf'].includes(sub.file_type)) { %>
                      <i data-lucide="file-text" class="w-5 h-5 text-red-500"></i>
                    <% } else if (['.doc','.docx'].includes(sub.file_type)) { %>
                      <i data-lucide="file-edit" class="w-5 h-5 text-blue-500"></i>
                    <% } else if (['.zip','.rar'].includes(sub.file_type)) { %>
                      <i data-lucide="package" class="w-5 h-5 text-amber-500"></i>
                    <% } else if (['.psd','.ai'].includes(sub.file_type)) { %>
                      <i data-lucide="palette" class="w-5 h-5 text-purple-500"></i>
                    <% } else { %>
                      <i data-lucide="file" class="w-5 h-5 text-gray-500"></i>
                    <% } %>
                  </div>
                  <div class="min-w-0 flex-1">
                    <p class="text-xs font-medium text-idb-blue-dark truncate"><%= sub.file_name %></p>
                    <p class="text-xs text-gray-400">
                      <%= sub.uploader_name %> · <%= new Date(sub.created_at).toLocaleDateString('id-ID') %>
                    </p>
                  </div>
                </div>
              </a>
            <% }) %>
          </div>
        <% } %>

        <% if (user.role === 'mahasiswa') { %>
          <div class="mt-4 pt-4 border-t border-gray-100">
            <form method="POST" action="/mahasiswa/proyek/upload/<%= project.id %>" enctype="multipart/form-data" class="space-y-2">
              <label class="text-xs font-medium text-gray-600 block">Unggah File Baru</label>
              <input type="file" name="files" multiple required class="w-full input text-xs file:bg-idb-blue file:text-white file:rounded-btn file:px-2 file:py-1 file:border-0 file:text-xs file:cursor-pointer" style="padding:4px" accept=".jpg,.jpeg,.png,.gif,.pdf,.doc,.docx,.zip,.rar,.txt,.psd,.ai,.svg">
              <button type="submit" class="btn btn-blue w-full" style="font-size:0.75rem;padding:8px">Unggah</button>
            </form>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</div>

<!-- Auto-scroll and polling script -->
<script>
document.addEventListener('DOMContentLoaded', () => {
  const container = document.getElementById('messages-container');
  // Scroll to bottom
  container.scrollTop = container.scrollHeight;

  // Polling for new messages every 5 seconds
  let lastId = <%= messages.length > 0 ? messages[messages.length - 1].id : 0 %>;
  const projectId = <%= project.id %>;
  const userId = <%= user.id %>;

  setInterval(() => {
    fetch('/chat/' + projectId + '/messages?after=' + lastId)
      .then(r => r.json())
      .then(msgs => {
        if (msgs.length > 0) {
          msgs.forEach(msg => {
            const isMine = msg.sender_id === userId;
            const div = document.createElement('div');
            div.className = 'flex ' + (isMine ? 'justify-end' : 'justify-start');
            div.innerHTML = '<div class="max-w-[75%] ' + (isMine ? 'bg-idb-blue text-white' : 'bg-white text-idb-charcoal border border-gray-100') + ' rounded-2xl px-4 py-2.5" style="' + (isMine ? 'border-bottom-right-radius:4px' : 'border-bottom-left-radius:4px') + '">' +
              (!isMine ? '<p class="text-xs font-semibold mb-0.5 ' + (isMine ? 'text-blue-200' : 'text-idb-blue') + '">' + msg.sender_name + '</p>' : '') +
              '<p class="text-sm leading-relaxed whitespace-pre-wrap">' + msg.message.replace(/</g, '&lt;').replace(/>/g, '&gt;') + '</p>' +
              '<p class="text-xs mt-1 ' + (isMine ? 'text-blue-200' : 'text-gray-400') + ' text-right">' + new Date(msg.created_at).toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit' }) + '</p>' +
            '</div>';
            container.appendChild(div);
            lastId = msg.id;
          });
          container.scrollTop = container.scrollHeight;
        }
      })
      .catch(() => {});
  }, 5000);
});

// Initialize Lucide icons
if (typeof lucide !== 'undefined') {
  lucide.createIcons();
}
</script>

<%- include('../partials/footer') %>

<%- include('../partials/header') %>

<nav class="bg-idb-blue border-b border-idb-blue-dark sticky top-0 z-40">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-wrap justify-between items-center gap-2 py-2 min-h-[3.5rem]">
      <button class="hamburger-btn" aria-label="Menu"><span></span><span></span><span></span></button>
      <a href="/mahasiswa/dashboard" class="flex items-center gap-2">
        <div class="bg-white rounded-lg px-2 py-1 shadow-sm"><img src="/images/logo.png" alt="StudentWorks" class="h-9 w-auto"></div>
        <span class="status-chip status-chip--blue ml-1" style="font-size:0.6rem;padding:2px 8px">Mahasiswa</span>
      </a>
      <div class="hidden md:flex md:flex-wrap md:items-center md:gap-4">
        <a href="/mahasiswa/dashboard" class="text-sm text-white hover:underline font-medium">Dashboard</a>
        <a href="/logout" class="text-sm text-white/80 hover:text-white font-medium">Keluar</a>
      </div>
    </div>
  </div>
</nav>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 page-fade-in">
  <div class="mb-6">
    <h2 class="font-heading text-2xl font-bold text-idb-blue-dark">Proyek Tersedia</h2>
    <p class="text-sm text-gray-500 mt-1">Temukan proyek yang sesuai dengan keahlianmu.</p>
  </div>

  <% if (isExamPeriod) { %>
    <div class="safe-zone-banner mb-6">
      <span class="text-xl">⚠️</span>
      <div>
        <strong class="font-heading"><%= examWarningMessage %></strong>
      </div>
    </div>
  <% } %>

  <% if (projects.length === 0) { %>
    <div class="empty-state">
      <div class="empty-state-icon" style="background:#EDF2F7">
        <i data-lucide="search-x" class="w-7 h-7"></i>
      </div>
      <p class="text-gray-500 text-sm">Belum ada proyek yang tersedia saat ini.</p>
    </div>
  <% } else { %>
    <div class="grid md:grid-cols-2 gap-5">
      <% projects.forEach(project => { %>
        <div class="card project-card p-6" style="--project-color:#0F4C81">
          <div class="flex justify-between items-start mb-3">
            <h4 class="font-heading font-semibold text-idb-blue-dark"><%= project.judul_proyek %></h4>
            <div class="flex gap-2 flex-wrap justify-end">
              <% if (isExamPeriod) { %>
                <span class="status-chip status-chip--amber text-xs flex items-center gap-1">
                  <i data-lucide="book-open" class="w-3 h-3"></i>
                  Ujian
                </span>
              <% } %>
              <% if (project.requires_test) { %>
                <span class="status-chip status-chip--blue text-xs flex items-center gap-1">
                  <i data-lucide="check-square" class="w-3 h-3"></i>
                  Quality Test
                </span>
              <% } %>
              <span class="status-chip status-chip--gray">Mencari Talenta</span>
            </div>
          </div>
          <p class="text-sm text-gray-500 mb-1">Klien: <%= project.klien_name %></p>
          <% if (project.deskripsi) { %>
            <p class="text-sm text-gray-600 mb-4 leading-relaxed"><%= project.deskripsi.substring(0, 100) %><%= project.deskripsi.length > 100 ? '...' : '' %></p>
          <% } %>
          <div class="grid grid-cols-2 gap-4 mb-4 text-sm">
            <div>
              <span class="font-semibold text-idb-blue">Anggaran:</span>
              <p class="text-idb-charcoal">Rp <%= project.anggaran.toLocaleString('id-ID') %></p>
            </div>
            <div>
              <span class="font-semibold text-idb-blue">Deadline:</span>
              <p class="text-idb-charcoal"><%= new Date(project.tenggat_waktu).toLocaleDateString('id-ID') %></p>
            </div>
          </div>
          <div class="bg-idb-gray p-3 rounded mb-4 border-l-2 border-idb-orange">
            <div class="flex items-center gap-2 mb-2">
              <i data-lucide="clipboard-list" class="w-4 h-4 text-idb-blue"></i>
              <span class="text-xs font-semibold text-idb-blue uppercase">Aturan Main</span>
            </div>
            <p class="text-xs text-idb-charcoal"><%= (project.custom_sla_rules || 'Fleksibel, komunikatif, dan selesai tepat waktu.').substring(0, 80) %>...</p>
          </div>
          <button 
            data-lamar-btn 
            data-project-id="<%= project.id %>"
            data-sla-rules="<%= project.custom_sla_rules || 'Fleksibel, komunikatif, dan selesai tepat waktu.' %>"
            data-is-exam-period="<%= isExamPeriod ? 'true' : 'false' %>"
            data-exam-period-info="<%= examPeriodInfo ? examPeriodInfo.nama_periode : '' %>"
            class="w-full btn btn-orange"
          >
            Lamar Sekarang
          </button>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>

<!-- Commitment Lock Modal -->
<div id="commitmentModal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black bg-opacity-50">
  <div class="bg-white rounded-card w-full max-w-2xl mx-4 max-h-[90vh] overflow-y-auto shadow-xl border border-gray-100">
    <div class="bg-gradient-to-r from-idb-blue-dark to-idb-blue p-6 text-white">
      <h2 class="text-2xl font-heading font-bold">Sadar Diri Sebelum Melamar</h2>
      <p class="text-sm mt-2 opacity-90">Baca aturan main klien dan pastikan kamu siap berkomitmen.</p>
    </div>
    <div class="p-6 space-y-6">
      <div class="bg-idb-gray p-4 rounded-card border-l-4 border-idb-orange">
        <h3 class="font-heading font-bold text-idb-charcoal mb-3 flex items-center gap-2">
          <i data-lucide="clipboard-list" class="w-5 h-5 text-idb-orange"></i>
          Aturan Main Klien
        </h3>
        <div id="slaRulesContent" class="text-sm text-idb-charcoal whitespace-pre-wrap font-body"></div>
      </div>
      <div class="bg-amber-50 p-4 rounded-card border-l-4 border-idb-amber">
        <h3 class="font-heading font-bold text-idb-charcoal mb-3 flex items-center gap-2">
          <i data-lucide="alert-triangle" class="w-5 h-5 text-amber-600"></i>
          Pernyataan Konsekuensi
        </h3>
        <p class="text-sm text-idb-charcoal font-body leading-relaxed">
          IDB Bali memberikanmu <strong>kebebasan penuh</strong> mengelola waktu dan proyek. Kamu boleh mengambil proyek ini meski sedang UTS/UAS. Namun, <strong>kamu bertanggung jawab sepenuhnya</strong> atas:
        </p>
        <ul class="list-disc list-inside mt-3 text-sm text-idb-charcoal space-y-1">
          <li>Nilai akademikmu di kampus</li>
          <li>Kualitas hasil kerja untuk klien</li>
          <li>Memenuhi aturan main yang disepakati</li>
          <li>Komunikasi yang jelas dan responsif</li>
        </ul>
        <p class="text-sm text-idb-charcoal font-bold mt-3 text-red-600 flex items-center gap-2">
          <i data-lucide="x-octagon" class="w-4 h-4"></i>
          Pelanggaran komitmen berakibat <strong>fatal pada skor reputasimu</strong>.
        </p>
      </div>
      <div id="examWarningBox" class="hidden bg-amber-100 p-4 rounded-card border-l-4 border-idb-amber">
        <h3 class="font-heading font-bold text-idb-charcoal mb-2 flex items-center gap-2">
          <i data-lucide="book-open" class="w-5 h-5 text-amber-600"></i>
          Catatan Periode Ujian
        </h3>
        <p id="examWarningText" class="text-sm text-idb-charcoal"></p>
      </div>
      <div class="flex items-start space-x-3 bg-blue-50 p-4 rounded-card">
        <input type="checkbox" id="commitmentCheckbox" class="mt-1 w-5 h-5 accent-idb-orange cursor-pointer">
        <label for="commitmentCheckbox" class="text-sm text-idb-charcoal font-body cursor-pointer">
          Saya setuju dengan aturan main di atas dan siap berkomitmen penuh terhadap proyek ini. Saya memahami risiko dan konsekuensinya.
        </label>
      </div>
    </div>
    <div class="bg-gray-50 border-t border-gray-200 px-6 py-4 flex justify-end gap-3 rounded-b-card">
      <button onclick="closeCommitmentModal()" class="btn btn-ghost px-4 py-2">Kembali</button>
      <button id="confirmCommitmentBtn" onclick="submitApplication()" disabled class="btn btn-orange px-6 py-2 disabled:opacity-50 disabled:cursor-not-allowed">
        Lamar dengan Komitmen
      </button>
    </div>
  </div>
</div>

<script>
let currentProjectData = null;

function openCommitmentModal(projectData) {
  currentProjectData = projectData;
  document.getElementById('slaRulesContent').textContent = projectData.custom_sla_rules;
  if (projectData.isExamPeriod) {
    document.getElementById('examWarningBox').classList.remove('hidden');
    document.getElementById('examWarningText').textContent = 
      `Kamu sedang dalam periode ${projectData.examPeriodInfo}. Pastikan prioritas akademikmu tetap terjaga!`;
  } else {
    document.getElementById('examWarningBox').classList.add('hidden');
  }
  document.getElementById('commitmentCheckbox').checked = false;
  updateCommitmentButtonState();
  document.getElementById('commitmentModal').classList.remove('hidden');
}

function closeCommitmentModal() {
  document.getElementById('commitmentModal').classList.add('hidden');
  currentProjectData = null;
}

document.getElementById('commitmentCheckbox').addEventListener('change', updateCommitmentButtonState);

function updateCommitmentButtonState() {
  const isChecked = document.getElementById('commitmentCheckbox').checked;
  const btn = document.getElementById('confirmCommitmentBtn');
  btn.disabled = !isChecked;
  if (isChecked) {
    btn.classList.remove('opacity-50', 'cursor-not-allowed');
    btn.classList.add('hover:bg-orange-600');
  } else {
    btn.classList.add('opacity-50', 'cursor-not-allowed');
    btn.classList.remove('hover:bg-orange-600');
  }
}

async function submitApplication() {
  if (!currentProjectData) return;
  const btn = document.getElementById('confirmCommitmentBtn');
  btn.disabled = true;
  btn.textContent = 'Melamar...';
  
  try {
    const response = await fetch('/mahasiswa/proyek/lamar', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        project_id: currentProjectData.id,
        commitment_signed: true
      })
    });
    
    const data = await response.json();
    if (response.ok) {
      closeCommitmentModal();
      alert('✓ ' + data.message);
      setTimeout(() => { window.location.href = '/mahasiswa/dashboard'; }, 500);
    } else {
      alert(data.error || 'Gagal mengirim lamaran');
      btn.disabled = false;
      btn.textContent = 'Lamar dengan Komitmen';
    }
  } catch (err) {
    alert('Error: ' + err.message);
    btn.disabled = false;
    btn.textContent = 'Lamar dengan Komitmen';
  }
}

document.querySelectorAll('[data-lamar-btn]').forEach(btn => {
  btn.addEventListener('click', function(e) {
    e.preventDefault();
    const projectData = {
      id: this.dataset.projectId,
      custom_sla_rules: this.dataset.slaRules || 'Fleksibel, komunikatif, dan selesai tepat waktu.',
      isExamPeriod: this.dataset.isExamPeriod === 'true',
      examPeriodInfo: this.dataset.examPeriodInfo || ''
    };
    openCommitmentModal(projectData);
  });
});

// Initialize Lucide icons
if (typeof lucide !== 'undefined') {
  lucide.createIcons();
}
</script>

<%- include('../partials/footer') %>

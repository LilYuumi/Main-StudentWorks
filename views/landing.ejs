<!-- ═══════════════════════════════════════════════
     SCRIPTS: GSAP Animations + Navbar Scroll + Lucide
     ═══════════════════════════════════════════════ -->
<script>
document.addEventListener('DOMContentLoaded', () => {
  // ── Initialize Lucide Icons ──
  if (typeof lucide !== 'undefined') lucide.createIcons();

  if (typeof gsap === 'undefined') return;
  gsap.registerPlugin(ScrollTrigger);

  // ── Navbar: solid on scroll ──
  const nav = document.getElementById('landing-nav');
  const navLinks = nav.querySelectorAll('.nav-link');
  const brand = nav.querySelector('.nav-brand');

  function updateNav() {
    const scrolled = window.scrollY > 50;
    nav.classList.toggle('scrolled', scrolled);
    navLinks.forEach(l => {
      l.style.color = '';
    });
  }
  window.addEventListener('scroll', updateNav, { passive: true });
  updateNav();

  // ── Hero: staggered entrance ──
  const heroTl = gsap.timeline({ defaults: { ease: 'power3.out' } });
  heroTl
    .from('#hero-badge', { y: 20, opacity: 0, duration: 0.5 })
    .from('#hero-title', { y: 50, opacity: 0, duration: 0.9 }, '-=0.3')
    .from('#hero-sub', { y: 35, opacity: 0, duration: 0.7 }, '-=0.5')
    .from('#hero-ctas', { y: 25, opacity: 0, duration: 0.6 }, '-=0.4')
    .from('#hero-trust', { y: 15, opacity: 0, duration: 0.5 }, '-=0.3');

  // ── Hero visual: image reveal ──
  gsap.from('#hero-visual .hero-image-wrapper', {
    scale: 0.92,
    opacity: 0,
    duration: 1,
    ease: 'power2.out',
    delay: 0.4
  });

  // ── Hero floating cards: stagger in ──
  gsap.from('.hero-float-card', {
    scale: 0.8,
    opacity: 0,
    duration: 0.6,
    stagger: 0.2,
    ease: 'back.out(1.7)',
    delay: 0.9
  });

  // ── Stats: count-up on scroll ──
  ScrollTrigger.create({
    trigger: '#stats-bar',
    start: 'top 80%',
    once: true,
    onEnter: () => {
      document.querySelectorAll('.stat-item p[data-count]').forEach(el => {
        const target = parseInt(el.dataset.count);
        gsap.fromTo(el, { innerText: 0 }, {
          innerText: target,
          duration: 1.8,
          ease: 'power2.out',
          snap: { innerText: 1 },
          onUpdate: function() {
            el.innerText = Math.round(gsap.getProperty(el, 'innerText'));
          }
        });
      });
    }
  });

  // ── Stats bar: slide up ──
  gsap.from('#stats-bar .stat-item', {
    scrollTrigger: { trigger: '#stats-bar', start: 'top 85%', once: true },
    y: 30, opacity: 0, duration: 0.5, stagger: 0.1, ease: 'power2.out'
  });

  // ── Value Proposition ──
  gsap.from('#value-header', {
    scrollTrigger: { trigger: '#value-header', start: 'top 80%', once: true },
    y: 30, opacity: 0, duration: 0.6, ease: 'power2.out'
  });
  gsap.from('.feature-card', {
    scrollTrigger: { trigger: '.feature-card', start: 'top 85%', once: true },
    y: 60, opacity: 0, duration: 0.7, stagger: 0.15, ease: 'power2.out'
  });

  // ── Talent Cards ──
  gsap.from('#talenta-header', {
    scrollTrigger: { trigger: '#talenta-header', start: 'top 80%', once: true },
    y: 30, opacity: 0, duration: 0.6, ease: 'power2.out'
  });
  gsap.from('.talent-card', {
    scrollTrigger: { trigger: '.talent-card', start: 'top 85%', once: true },
    y: 50, opacity: 0, duration: 0.6, stagger: 0.1, ease: 'power2.out'
  });

  // ── Steps ──
  gsap.from('#steps-header', {
    scrollTrigger: { trigger: '#steps-header', start: 'top 80%', once: true },
    y: 30, opacity: 0, duration: 0.6, ease: 'power2.out'
  });
  gsap.from('.step-card', {
    scrollTrigger: { trigger: '.step-card', start: 'top 85%', once: true },
    y: 50, opacity: 0, scale: 0.9, duration: 0.6, stagger: 0.12, ease: 'back.out(1.4)'
  });

  // ── Testimonials ──
  gsap.from('#testimonial-header', {
    scrollTrigger: { trigger: '#testimonial-header', start: 'top 80%', once: true },
    y: 30, opacity: 0, duration: 0.6, ease: 'power2.out'
  });
  gsap.from('.testimonial-card', {
    scrollTrigger: { trigger: '.testimonial-card', start: 'top 85%', once: true },
    y: 50, opacity: 0, duration: 0.6, stagger: 0.15, ease: 'power2.out'
  });

  // ── CTA ──
  gsap.from('#cta-title', {
    scrollTrigger: { trigger: '#cta-section', start: 'top 80%', once: true },
    y: 30, opacity: 0, duration: 0.7, ease: 'power2.out'
  });
  gsap.from('#cta-sub', {
    scrollTrigger: { trigger: '#cta-section', start: 'top 80%', once: true },
    y: 20, opacity: 0, duration: 0.6, delay: 0.15, ease: 'power2.out'
  });
  gsap.from('#cta-btns', {
    scrollTrigger: { trigger: '#cta-section', start: 'top 80%', once: true },
    y: 20, opacity: 0, duration: 0.6, delay: 0.3, ease: 'power2.out'
  });

  // ── Navbar entrance ──
  gsap.from('#landing-nav', { y: -30, opacity: 0, duration: 0.6, ease: 'power2.out', delay: 0.1 });

  // ── Smooth scroll for anchor links ──
  document.querySelectorAll('a[href^="#"]').forEach(anchor => {
    anchor.addEventListener('click', function(e) {
      e.preventDefault();
      const target = document.querySelector(this.getAttribute('href'));
      if (target) {
        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  });

  // ── Safety net: force visibility if ScrollTrigger didn't fire ──
  // Refresh ScrollTrigger multiple times as layout settles from images/fonts loading
  const refreshSchedule = [100, 300, 600, 1200, 2500];
  refreshSchedule.forEach(ms => {
    setTimeout(() => ScrollTrigger.refresh(), ms);
  });
  window.addEventListener('load', () => ScrollTrigger.refresh());

  // Force-reveal all images when they load (prevents layout shift after GSAP init)
  document.querySelectorAll('img').forEach(img => {
    if (!img.complete) {
      img.addEventListener('load', () => ScrollTrigger.refresh(), { once: true });
    }
  });

  // Hard fallback: if anything is still invisible after 2s, force-reveal it
  setTimeout(() => {
    document.querySelectorAll('.feature-card, .talent-card, .step-card, .testimonial-card, .stat-item, #value-header, #talenta-header, #steps-header, #testimonial-header, #cta-title, #cta-sub, #cta-btns, #stats-bar, #hero-visual .hero-image-wrapper, .hero-float-card, #hero-badge, #hero-title, #hero-sub, #hero-ctas, #hero-trust, #landing-nav').forEach(el => {
      if (parseFloat(getComputedStyle(el).opacity) < 0.5) {
        gsap.set(el, { opacity: 1, y: 0, scale: 1 });
      }
    });
  }, 2000);
});
</script>


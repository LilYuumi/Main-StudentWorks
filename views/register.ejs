<%- include('partials/header') %>

<div class="min-h-screen flex items-center justify-center py-12 px-4 auth-bg page-fade-in">
  <div class="max-w-md w-full">
    <div class="text-center mb-8">
      <a href="/" class="inline-flex items-center gap-2 mb-6">
        <img src="/images/logo.png" alt="StudentWorks" class="h-12 w-auto">
      </a>
      <h2 class="font-heading text-2xl font-bold text-idb-blue-dark">Daftar Akun Baru</h2>
      <p class="text-sm text-gray-500 mt-1">Bergabung dengan StudentWorks</p>
    </div>
    <div class="card p-8">
      <form method="POST" action="/register" class="space-y-4">
        <div>
          <label class="text-sm font-medium text-gray-700 block mb-1">Nama Lengkap</label>
          <input type="text" name="name" required class="input" placeholder="Nama lengkap">
        </div>
        <div>
          <label class="text-sm font-medium text-gray-700 block mb-1">Email</label>
          <input type="email" name="email" required class="input" placeholder="nama@email.com">
        </div>
        <div>
          <label class="text-sm font-medium text-gray-700 block mb-1">Password</label>
          <input type="password" name="password" required minlength="6" class="input" placeholder="Minimal 6 karakter">
        </div>
        <div>
          <label class="text-sm font-medium text-gray-700 block mb-2">Daftar Sebagai</label>
          <div class="grid grid-cols-2 gap-3">
            <label class="relative cursor-pointer">
              <input type="radio" name="role" value="mahasiswa" class="peer sr-only" checked>
              <div class="p-3 border-2 border-gray-200 rounded-card text-center peer-checked:border-idb-blue peer-checked:bg-idb-blue/5 transition">
                <p class="font-heading font-medium text-sm">Mahasiswa</p>
                <p class="text-xs text-gray-500 mt-0.5">Cari proyek freelance</p>
              </div>
            </label>
            <label class="relative cursor-pointer">
              <input type="radio" name="role" value="klien" class="peer sr-only">
              <div class="p-3 border-2 border-gray-200 rounded-card text-center peer-checked:border-idb-orange peer-checked:bg-idb-orange/5 transition">
                <p class="font-heading font-medium text-sm">Klien</p>
                <p class="text-xs text-gray-500 mt-0.5">Cari talenta</p>
              </div>
            </label>
          </div>
        </div>
        <button type="submit" class="btn btn-orange w-full">Daftar Sekarang</button>
      </form>
      <div class="mt-5 text-center">
        <p class="text-sm text-gray-500">Sudah punya akun? <a href="/login" class="text-idb-blue font-medium hover:underline">Masuk di sini</a></p>
      </div>
    </div>
    <div class="text-center mt-4">
      <a href="/" class="text-sm text-gray-500 hover:text-idb-blue font-medium">&larr; Kembali ke Beranda</a>
    </div>
  </div>
</div>

<%- include('partials/footer') %>

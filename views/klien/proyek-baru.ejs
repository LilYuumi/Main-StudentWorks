<%- include('../partials/header') %>

<nav class="bg-idb-blue border-b border-idb-blue-dark sticky top-0 z-40">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-wrap justify-between items-center gap-2 py-2 min-h-[3.5rem]">
      <button class="hamburger-btn" aria-label="Menu"><span></span><span></span><span></span></button>
      <a href="/klien/dashboard" class="flex items-center gap-2">
        <div class="bg-white rounded-lg px-2 py-1 shadow-sm"><img src="/images/logo.png" alt="StudentWorks" class="h-9 w-auto"></div>
                <span class="status-chip ml-1" style="font-size:0.6rem;padding:2px 8px;background:#FF6B35;color:white">Klien</span>
      </a>
      <div class="hidden md:flex md:flex-wrap md:items-center md:gap-4">
        <a href="/klien/dashboard" class="text-sm text-white hover:underline font-medium">Dashboard</a>
        <a href="/logout" class="text-sm text-white/80 hover:text-white font-medium">Keluar</a>
      </div>
    </div>
  </div>
</nav>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 page-fade-in">
  <div class="mb-6">
    <h2 class="font-heading text-2xl font-bold text-idb-blue-dark">Buat Proyek Baru</h2>
    <p class="text-sm text-gray-500 mt-1">Isi detail proyek yang ingin Anda buat.</p>
  </div>

  <div class="max-w-2xl">
    <div class="card p-8">
      <form method="POST" action="/klien/proyek/baru" class="space-y-5">
        <div>
          <label class="text-sm font-medium text-gray-700 mb-1 block">Judul Proyek</label>
          <input type="text" name="judul_proyek" required class="input" placeholder="Contoh: Desain Logo UMKM Bali">
        </div>
        <div>
          <label class="text-sm font-medium text-gray-700 mb-1 block">Deskripsi Proyek</label>
          <textarea name="deskripsi" rows="5" required class="input" placeholder="Jelaskan detail proyek, kebutuhan, dan ekspektasi Anda..."></textarea>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label class="text-sm font-medium text-gray-700 mb-1 block">Anggaran (Rp)</label>
            <input type="number" name="anggaran" required min="100000" class="input" placeholder="2500000">
          </div>
          <div>
            <label class="text-sm font-medium text-gray-700 mb-1 block">Tenggat Waktu</label>
            <input type="date" name="tenggat_waktu" required class="input">
          </div>
        </div>
        <div>
          <label class="text-sm font-medium text-gray-700 mb-1 block">Aturan Main Komitmen (SLA)</label>
          <textarea name="custom_sla_rules" rows="4" class="input" placeholder="Contoh:&#10;1. Update harian via WhatsApp&#10;2. Harus responsif dalam 2 jam kerja&#10;3. Revisi maksimal 2x putaran">Fleksibel, komunikatif, dan selesai tepat waktu.</textarea>
          <p class="text-xs text-gray-500 mt-1">Sampaikan harapan Anda agar mahasiswa mengerti tanggung jawabnya.</p>
        </div>
        <div class="flex items-start gap-2 bg-blue-50 p-3 rounded-card border border-blue-100">
          <input type="checkbox" name="requires_test" id="requires_test" class="mt-1 w-4 h-4 accent-idb-blue">
          <label for="requires_test" class="text-sm text-idb-charcoal cursor-pointer">
            <strong>Wajib Uji Kualitas</strong> <br>
            <span class="text-xs text-gray-600">Mahasiswa harus lulus tes kualitas hasil kerja sebelum dana escrow dicairkan.</span>
          </label>
        </div>
        <div class="flex gap-3 pt-2">
          <a href="/klien/dashboard" class="btn btn-ghost flex-1">Batal</a>
          <button type="submit" class="btn btn-orange flex-1">Publikasikan Proyek</button>
        </div>
      </form>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
